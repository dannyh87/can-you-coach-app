generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String                @id @default(cuid())
  clerkUserId                  String?               @unique
  email                        String                @unique
  passwordHash                 String?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  clubs                        Club[]
  fitnessTestTypes             FitnessTestType[]
  memberships                  ClubMembership[]
  spectatorAccess              SpectatorAccess[]
  submittedMatchEvents         SubmittedMatchEvent[] @relation("SubmittedMatchEvents")
  acceptedSubmittedMatchEvents SubmittedMatchEvent[] @relation("AcceptedSubmittedMatchEvents")
}

enum ClubRole {
  OWNER
  COACH
  ASSISTANT_COACH
  VIEWER
}

model Club {
  id          String            @id @default(cuid())
  userId      String
  name        String
  location    String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  teams       Team[]
  memberships ClubMembership[]
  spectators  SpectatorAccess[]
}

model ClubMembership {
  id              String           @id @default(cuid())
  userId          String
  clubId          String
  role            ClubRole
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  club            Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  teamAssignments TeamAssignment[]

  @@unique([userId, clubId])
}

model TeamAssignment {
  id           String         @id @default(cuid())
  membershipId String
  teamId       String
  createdAt    DateTime       @default(now())
  membership   ClubMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([membershipId, teamId])
}

model Team {
  id                  String               @id @default(cuid())
  clubId              String
  name                String
  ageGroup            String
  season              String
  league              String?
  footballPyramidStep String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  club                Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  players             Player[]
  fitnessTestSessions FitnessTestSession[]
  matchDays           MatchDay[]
  assignments         TeamAssignment[]
}

model MatchDay {
  id                   String                @id @default(cuid())
  teamId               String
  kickoffAt            DateTime
  opposition           String
  matchType            MatchType
  venue                MatchVenue
  ownScore             Int                   @default(0)
  oppositionScore      Int                   @default(0)
  status               MatchStatus           @default(DRAFT)
  firstHalfStartedAt   DateTime?
  firstHalfEndedAt     DateTime?
  secondHalfStartedAt  DateTime?
  secondHalfEndedAt    DateTime?
  completedAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  team                 Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matchDayPlayers      MatchDayPlayer[]
  matchPlayerStints    MatchPlayerStint[]
  matchEvents          MatchEvent[]
  matchDayEventTypes   MatchDayEventType[]
  submittedMatchEvents SubmittedMatchEvent[]
}

model MatchDayEventType {
  id                String             @id @default(cuid())
  matchDayId        String
  eventType         MatchEventType?
  category          MatchEventCategory
  eventDefinitionId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  matchDay          MatchDay           @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  eventDefinition   EventDefinition?   @relation(fields: [eventDefinitionId], references: [id], onDelete: SetNull)

  @@unique([matchDayId, eventType])
  @@unique([matchDayId, eventDefinitionId])
  @@index([eventDefinitionId])
}

model MatchDayPlayer {
  id                  String             @id @default(cuid())
  matchDayId          String
  playerId            String
  squadStatus         MatchSquadStatus   @default(NOT_INVOLVED)
  startingPosition    String?
  shirtNumberSnapshot Int?
  isTracked           Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  matchDay            MatchDay           @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  player              Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  stints              MatchPlayerStint[]

  @@unique([matchDayId, playerId])
}

model MatchPlayerStint {
  id               String         @id @default(cuid())
  matchDayId       String
  matchDayPlayerId String
  playerId         String
  half             MatchHalf
  startedAt        DateTime
  endedAt          DateTime?
  startMatchSecond Int?
  endMatchSecond   Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  matchDay         MatchDay       @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  matchDayPlayer   MatchDayPlayer @relation(fields: [matchDayPlayerId], references: [id], onDelete: Cascade)
  player           Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model MatchEvent {
  id                    String           @id @default(cuid())
  matchDayId            String
  playerId              String?
  eventType             MatchEventType?
  half                  MatchHalf
  matchSecond           Int
  ownScoreAtTime        Int
  oppositionScoreAtTime Int
  x                     Float?
  y                     Float?
  eventDefinitionId     String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  matchDay              MatchDay         @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  player                Player?          @relation(fields: [playerId], references: [id], onDelete: SetNull)
  eventDefinition       EventDefinition? @relation(fields: [eventDefinitionId], references: [id], onDelete: SetNull)

  @@index([eventDefinitionId])
}

model SubmittedMatchEvent {
  id                    String                    @id @default(cuid())
  matchDayId            String
  playerId              String
  submittedByUserId     String
  eventType             MatchEventType
  half                  MatchHalf
  matchSecond           Int
  ownScoreAtTime        Int
  oppositionScoreAtTime Int
  note                  String?
  status                SubmittedMatchEventStatus @default(PENDING)
  acceptedAt            DateTime?
  acceptedByUserId      String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  matchDay              MatchDay                  @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  player                Player                    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  submittedBy           User                      @relation("SubmittedMatchEvents", fields: [submittedByUserId], references: [id], onDelete: Cascade)
  acceptedBy            User?                     @relation("AcceptedSubmittedMatchEvents", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([matchDayId, playerId])
  @@index([submittedByUserId])
  @@index([status])
}

model EventDefinition {
  id                 String                    @id @default(cuid())
  scope              EventDefinitionScope      @default(GLOBAL)
  clubId             String?
  createdByUserId    String?
  legacyEventType    MatchEventType?           @unique
  name               String
  slug               String                    @unique
  normalizedName     String                    @unique
  description        String?
  videoUrl           String?
  matchPhase         EventDefinitionMatchPhase
  category           EventDefinitionCategory
  subcategory        String?
  agePhases          EventDefinitionAgePhase[]
  fourCorner         EventDefinitionFourCorner
  positionRelevance  EventDefinitionPosition[]
  enabledByDefault   Boolean                   @default(false)
  benchmarkable      Boolean                   @default(false)
  requiresLocation   Boolean                   @default(false)
  isActive           Boolean                   @default(true)
  archivedAt         DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  matchEvents        MatchEvent[]
  matchDayEventTypes MatchDayEventType[]

  @@index([scope])
  @@index([clubId])
  @@index([isActive])
  @@index([scope, isActive])
  @@index([category])
  @@index([subcategory])
  @@index([requiresLocation])
  @@index([createdByUserId])
  @@index([enabledByDefault])
  @@index([benchmarkable])
}

enum MatchType {
  LEAGUE
  CUP
  FRIENDLY
}

enum MatchVenue {
  HOME
  AWAY
  NEUTRAL
}

enum MatchStatus {
  DRAFT
  IN_PROGRESS
  HALF_TIME
  COMPLETED
}

enum MatchSquadStatus {
  STARTER
  SUBSTITUTE
  NOT_INVOLVED
}

enum MatchHalf {
  FIRST_HALF
  SECOND_HALF
}

enum MatchEventType {
  GOAL
  ASSIST
  SHOT_ON_TARGET
  SHOT_OFF_TARGET
  PASS_COMPLETE
  PASS_INCOMPLETE
  ONE_V_ONE_SUCCESS
  ONE_V_ONE_UNSUCCESSFUL
  TOUCH
}

enum MatchEventCategory {
  ATTACKING
  IN_POSSESSION
  OUT_OF_POSSESSION
  TRANSITION
}

enum SubmittedMatchEventStatus {
  PENDING
  ACCEPTED
  IGNORED
}

enum EventDefinitionScope {
  GLOBAL
  CLUB
}

enum EventDefinitionMatchPhase {
  IN_POSSESSION
  OUT_OF_POSSESSION
  TRANSITION
  SET_PIECES
  DISCIPLINE_MATCH_ADMIN
}

enum EventDefinitionCategory {
  PASSING
  RECEIVING
  DRIBBLING_1V1
  SHOOTING
  DEFENDING
  GOALKEEPING
  DISCIPLINE
  INJURIES
  OTHER
}

enum EventDefinitionAgePhase {
  FOUNDATION
  YOUTH
  ADULT
}

enum EventDefinitionFourCorner {
  TECHNICAL
  TACTICAL
  PHYSICAL
  PSYCHOLOGICAL_SOCIAL
}

enum EventDefinitionPosition {
  ALL
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
  WIDE_PLAYER
  CENTRAL_PLAYER
}

model Player {
  id                   String                @id @default(cuid())
  teamId               String
  firstName            String
  surname              String
  squadNumber          Int?
  preferredPosition    String?
  dateOfBirth          DateTime?
  joinedClubDate       DateTime?
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  team                 Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fitnessTestResults   FitnessTestResult[]
  matchDayPlayers      MatchDayPlayer[]
  matchPlayerStints    MatchPlayerStint[]
  matchEvents          MatchEvent[]
  spectatorAccess      SpectatorAccess[]
  submittedMatchEvents SubmittedMatchEvent[]
}

model SpectatorAccess {
  id        String   @id @default(cuid())
  userId    String
  clubId    String
  playerId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId, userId])
  @@index([userId])
}

model FitnessTestType {
  id                     String               @id @default(cuid())
  userId                 String?
  name                   String
  description            String?
  resultUnit             String
  higherIsBetter         Boolean
  allowedRecordingModes  String               @default("MANUAL")
  preferredRecordingMode String               @default("MANUAL")
  isDefault              Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  user                   User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  fitnessTestSessions    FitnessTestSession[]

  @@unique([userId, name])
}

model FitnessTestSession {
  id                String                   @id @default(cuid())
  teamId            String
  fitnessTestTypeId String
  date              DateTime
  notes             String?
  status            FitnessTestSessionStatus @default(DRAFT)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  team              Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fitnessTestType   FitnessTestType          @relation(fields: [fitnessTestTypeId], references: [id], onDelete: Restrict)
  results           FitnessTestResult[]
}

enum FitnessTestSessionStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

model FitnessTestResult {
  id                   String              @id @default(cuid())
  fitnessTestSessionId String
  playerId             String
  resultValue          Float?
  resultText           String?
  status               FitnessResultStatus @default(COMPLETED)
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  fitnessTestSession   FitnessTestSession  @relation(fields: [fitnessTestSessionId], references: [id], onDelete: Cascade)
  player               Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([fitnessTestSessionId, playerId])
}

enum FitnessResultStatus {
  COMPLETED
  DID_NOT_START
  INJURED
  ABSENT
  DROPPED_OUT
}
